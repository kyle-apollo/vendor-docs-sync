# ─────────────────────────────────────────────────────────────────────────────
# Environment variable template for sample_project
#
# Copy this file to .env and fill in the real values:
#   cp .env.example .env
#
# Do NOT commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# VendorX API key — obtain from the VendorX portal under API Keys.
# Format: sk_live_ followed by 32 alphanumeric characters.
# Placeholder below is non-functional; replace before use.
VENDORX_API_KEY=sk_live_REPLACE_WITH_YOUR_KEY_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Ingest endpoint (leave blank to use the value in app_config.yaml).
VENDORX_ENDPOINT=

# Application environment tag attached to every event.
# Valid values: development | staging | production
APP_ENV=development

# Connector log verbosity.
# Valid values: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# Optional: override the config file path loaded by the agent.
# VENDORX_CONFIG_PATH=sample_project/app_config.yaml
# ─────────────────────────────────────────────────────────────────────────────
